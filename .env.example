# LLM API key for intake (required). Use ONE of these:
# Option A: Project-specific key (recommended - avoids shell env conflicts)
AURELIA_LLM_API_KEY=sk-...

# Option B: xAI Grok (get key at https://console.x.ai)
# XAI_API_KEY=xai-...

# Option C: OpenAI (may be overridden by OPENAI_API_KEY in your shell)
# OPENAI_API_KEY=sk-...

# MongoDB connection string (required for persisting preferences and auth)
# Get a free cluster at: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/aurelia

# Auth.js secret (REQUIRED for authentication - login will fail without it)
# Generate with: openssl rand -base64 32
# Then paste the output here:
AUTH_SECRET=YBk1OnD8qS7+9Ej2D/vM/X8C8efkU6VwzbRGKphDw5k=

# Spoonacular API key (for Planning agent)
# Get at: https://spoonacular.com/food-api/console
# SPOONACULAR_API_KEY=your_key_here

# Browser Use Cloud - DoorDash & Instacart (see docs/DOORDASH_AUTH.md, docs/INSTACART_SETUP.md)
# BROWSER_USE_API_KEY=bu_...  # Get at cloud.browser-use.com/settings?tab=api-keys
# BROWSER_USE_PROFILE_ID=...  # Profile sync - same profile works for DoorDash AND Instacart
# BROWSER_USE_SKILL_ID=...    # DoorDash skill UUID - faster than run() when used with profile
# BROWSER_USE_OP_VAULT_ID=... # 1Password - docs/1PASSWORD_SETUP.md
# DOORDASH_EMAIL=... DOORDASH_PASSWORD=...  # Credentials - docs/2FA_OPTIONS.md
# GMAIL_APP_PASSWORD=...  # Optional: auto-fetch 2FA from Gmail
